{
  "name": "bzxz",
  "version": "1.0.0",
  "description": "多源标准检索与批量下载",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:dev": "vitest",
    "electron:dev": "tsc -p tsconfig.electron.json && electron .",
    "electron:build": "tsc -p tsconfig.electron.json && electron-builder --win portable",
    "electron:dist": "tsc -p tsconfig.electron.json && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.bzxz.app",
    "productName": "bzxz",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "scripts/ocr_ddddocr.py",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts/ocr_ddddocr.py",
        "to": "scripts/ocr_ddddocr.py"
      },
      {
        "from": "data/accounts.json",
        "to": "data/accounts.json"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/favicon-256.png"
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@types/cheerio": "^0.22.35",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}
